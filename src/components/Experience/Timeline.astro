---
import { experiences } from '../../data/experience';
---

<section
  id="experience"
  class="relative py-14 md:py-28 overflow-hidden"
  aria-label="Experience and Education section"
>
  <div class="section-padding max-w-7xl mx-auto">

    <!-- Section label -->
    <div class="flex items-center gap-4 mb-6 reveal-hidden">
      <span class="text-accent text-sm font-body tracking-widest uppercase">03 — Experience</span>
      <span class="h-px flex-1 max-w-16 bg-accent/30" aria-hidden="true"></span>
    </div>

    <h2
      class="font-heading font-bold leading-tight mb-12 md:mb-16 reveal-hidden"
      style="font-size: clamp(2rem, 5vw, 3.5rem);"
    >
      My <span class="text-gradient">Journey</span>
    </h2>

    <!-- Timeline -->
    <div class="timeline-container relative" role="list" aria-label="Work experience and education timeline">

      <!-- Vertical line — only on md+ -->
      <div
        class="timeline-line hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-border -translate-x-1/2"
        aria-hidden="true"
      >
        <div
          class="timeline-progress absolute top-0 left-0 w-full bg-accent origin-top"
          style="height: 0%;"
          aria-hidden="true"
        ></div>
      </div>

      {experiences.map((exp, index) => {
        const isEdu   = exp.type === 'education';
        const isLeft  = index % 2 === 0;

        // Badge colour per type
        const badgeClass =
          exp.type === 'full-time'  ? 'border-accent/30 text-accent bg-accent/5' :
          exp.type === 'internship' ? 'border-emerald-400/30 text-emerald-400 bg-emerald-400/5' :
          exp.type === 'education'  ? 'border-accent/30 text-accent bg-accent/5' :
          exp.type === 'freelance'  ? 'border-amber-400/30 text-amber-400 bg-amber-400/5' :
                                      'border-border text-secondary bg-border/20';

        const badgeLabel =
          exp.type === 'full-time'  ? 'Full-time' :
          exp.type === 'internship' ? 'Internship' :
          exp.type === 'education'  ? 'Education' :
          exp.type === 'freelance'  ? 'Freelance' : exp.type;

        return (
          <div
            class={`timeline-item relative flex mb-10 last:mb-0 md:mb-14 ${isLeft ? 'md:justify-start' : 'md:justify-end'}`}
            role="listitem"
            data-index={index}
          >
            <!-- Timeline dot (md+) -->
            <div
              class={`timeline-dot hidden md:block absolute left-1/2 top-8 w-3.5 h-3.5 rounded-full bg-bg border-2 -translate-x-1/2 z-10 border-accent`}
              aria-hidden="true"
            >
              <div class="absolute inset-0.5 rounded-full bg-accent/40"></div>
            </div>

            <!-- Card -->
            <div
              class={`
                timeline-card rounded-2xl p-6 md:p-8
                w-full md:w-[calc(50%-3rem)]
                ${isLeft ? 'md:mr-auto' : 'md:ml-auto'}
                border border-border bg-surface
              `}
            >
              <!-- Education icon (shown only for education type) -->
              {isEdu && (
                <div class="flex items-center gap-3 mb-4" aria-hidden="true">
                  <div class="w-9 h-9 rounded-xl border border-accent/20 bg-accent/5 flex items-center justify-center text-accent flex-shrink-0">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                      <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                    </svg>
                  </div>
                  <span class="text-accent text-xs font-body tracking-widest uppercase">Education</span>
                </div>
              )}

              <!-- Type badge -->
              <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-body tracking-wider uppercase mb-3 border ${badgeClass}`}>
                {badgeLabel}
              </span>

              <!-- Period + Location row -->
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3">
                <p class="text-secondary text-sm font-body">{exp.period}</p>
                {exp.location && (
                  <span class="text-secondary/40 text-xs font-body">·</span>
                  <p class="text-secondary/60 text-xs font-body">{exp.location}</p>
                )}
              </div>

              <!-- Role & Company -->
              <h3 class="font-heading font-bold text-primary text-lg md:text-xl mb-1 leading-tight">{exp.role}</h3>
              <p class={`font-body text-sm mb-4 text-accent`}>{exp.company}</p>

              <!-- Description -->
              {exp.description && (
                <p class="text-secondary leading-relaxed mb-5 text-sm">{exp.description}</p>
              )}

              <!-- Highlights -->
              {exp.highlights.length > 0 && (
                <ul class="space-y-2 mb-5" aria-label="Key highlights">
                  {exp.highlights.map((h) => (
                    <li class="flex items-start gap-3 text-sm text-secondary">
                      <span class="text-accent mt-1 flex-shrink-0" aria-hidden="true">→</span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              )}

              <!-- UAE Attestation badge for education -->
              {exp.extra && (
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/20 bg-accent/5 mb-4">
                  <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-accent" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                  <span class="text-accent text-xs font-body">{exp.extra}</span>
                </div>
              )}

              <!-- Tech tags (skip for education) -->
              {exp.technologies.length > 0 && (
                <div class="flex flex-wrap gap-2" aria-label="Technologies used">
                  {exp.technologies.map((tech) => (
                    <span class="px-3 py-1 rounded-full bg-bg border border-border text-secondary text-xs font-body hover:text-accent hover:bg-accent/5 transition-colors duration-300">
                      {tech}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  import { initTimelineAnimations } from './TimelineAnimations';
  initTimelineAnimations();
</script>
