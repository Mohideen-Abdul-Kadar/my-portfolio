---
import { profile } from '../../data/profile';
---

<section
  id="hero"
  class="relative flex items-center justify-center overflow-hidden bg-bg"
  style="min-height: 100svh; min-height: 100vh; padding-top: max(5rem, env(safe-area-inset-top, 5rem)); padding-bottom: 3rem;"
  aria-label="Hero section"
>
  <!-- Background grid -->
  <div class="absolute inset-0 bg-grid opacity-30" aria-hidden="true"></div>

  <!-- Radial glow -->
  <div class="absolute inset-0 bg-radial-accent pointer-events-none" id="hero-glow" aria-hidden="true"></div>

  <!-- Floating orbs (parallax layers) -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" id="hero-parallax">
    <div class="orb absolute top-[15%] left-[10%] w-64 h-64 rounded-full" data-depth="0.3"
      style="background: radial-gradient(circle, rgba(0,229,255,0.08) 0%, transparent 70%);"></div>
    <div class="orb absolute top-[60%] right-[8%] w-96 h-96 rounded-full" data-depth="0.15"
      style="background: radial-gradient(circle, rgba(167,139,250,0.06) 0%, transparent 70%);"></div>
    <div class="orb absolute bottom-[20%] left-[30%] w-48 h-48 rounded-full" data-depth="0.2"
      style="background: radial-gradient(circle, rgba(0,229,255,0.05) 0%, transparent 70%);"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 section-padding w-full max-w-7xl mx-auto">
    <div class="max-w-5xl">

      <!-- Name — first element, biggest impact -->
      <h1
        class="hero-name font-heading font-bold leading-none tracking-tight mb-3"
        style="font-size: clamp(2rem, 6.5vw, 6rem);"
      >
        <span class="block overflow-hidden">
          <span class="hero-name-line text-primary block">{profile.name}</span>
        </span>
      </h1>

      <!-- Role -->
      <div class="hero-role overflow-hidden mb-4">
        <p class="font-heading text-accent font-medium tracking-widest uppercase"
          style="font-size: clamp(0.75rem, 1.5vw, 1rem);">
          {profile.role}
        </p>
      </div>

      <!-- Availability badge — NOW below name/role, different colour -->
      <div
        class="hero-badge inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald-400/25 bg-emerald-400/8 mb-6"
        aria-label="Open to relocation to Dubai"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse flex-shrink-0"></span>
        <span class="text-emerald-400 font-body tracking-wider uppercase whitespace-nowrap"
          style="font-size: clamp(0.6rem, 1.8vw, 0.72rem);">
          Open to relocation · Dubai · Immediate Joiner
        </span>
      </div>

      <!-- Tagline -->
      <p
        class="hero-tagline text-secondary leading-relaxed max-w-2xl mb-8 md:mb-12"
        style="font-size: clamp(0.95rem, 2vw, 1.25rem);"
      >
        {profile.tagline}
      </p>

      <!-- CTA Buttons -->
      <div class="hero-cta flex flex-wrap gap-4 opacity-0">
        <a
          href="#projects"
          class="magnetic-btn group relative px-8 py-4 bg-accent text-bg font-heading font-semibold rounded-full overflow-hidden transition-shadow duration-300 glow"
          data-magnetic
          aria-label="View my projects"
        >
          <span data-magnetic-inner class="relative z-10">View Work</span>
          <span class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out" aria-hidden="true"></span>
        </a>

        <!-- Download CV — simple anchor, Vercel header forces download in prod -->
        <a
          id="download-cv-btn"
          href={profile.resume}
          class="magnetic-btn group relative px-8 py-4 border border-border text-primary font-heading font-semibold rounded-full overflow-hidden hover:border-accent/40 transition-colors duration-300 inline-flex items-center"
          data-magnetic
          aria-label="Download resume PDF"
        >
          <span data-magnetic-inner class="relative z-10 flex items-center gap-2">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Download CV
          </span>
          <span class="absolute inset-0 bg-accent/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out" aria-hidden="true"></span>
        </a>
      </div>

      <!-- Social links — no separator line between them -->
      <div class="hero-socials flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 mt-8 md:mt-10">
        {profile.socials.map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-secondary hover:text-accent transition-colors duration-300 text-sm font-body tracking-wider"
            aria-label={`Visit ${s.label}`}
          >
            {s.label}
          </a>
        ))}
        <!-- No h-px separator — removed to avoid underline appearance -->
        <a
          href={`mailto:${profile.email}`}
          class="text-secondary hover:text-accent transition-colors duration-300 text-sm font-body break-all"
          aria-label={`Email ${profile.email}`}
        >
          {profile.email}
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  import { initHeroAnimations } from './HeroAnimations';
  initHeroAnimations();

  // ── CV Download: works on Vercel (Content-Disposition header set in vercel.json)
  // In local dev: opens PDF in new tab (user can Ctrl+S / Cmd+S to save)
  const cvLink = document.getElementById('download-cv-btn') as HTMLAnchorElement | null;
  if (cvLink) {
    cvLink.addEventListener('click', (e: MouseEvent) => {
      e.preventDefault();
      const url = cvLink.getAttribute('href') ?? '/resume.pdf';

      // Create a hidden <a> and trigger it — works in deployed environment
      // where vercel.json sends Content-Disposition: attachment
      const a = document.createElement('a');
      a.href     = url;
      a.download = 'Mohideen_Abdul_Kadar_CV.pdf';
      a.target   = '_blank';          // fallback: new tab if download blocked
      a.rel      = 'noopener';
      a.style.display = 'none';
      document.body.appendChild(a);
      a.click();
      setTimeout(() => a.remove(), 500);
    });
  }
</script>
