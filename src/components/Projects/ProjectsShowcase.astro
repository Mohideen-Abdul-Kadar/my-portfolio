---
import { projects } from '../../data/projects';

const accentRgb = [
  '0,229,255',
  '139,92,246',
  '52,211,153',
  '251,146,60',
];
---

<section
  id="projects"
  class="relative py-32"
  aria-label="Projects section"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(0,229,255,0.04) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="section-padding max-w-7xl mx-auto">
    <div class="flex items-center gap-4 mb-6 proj-header-el">
      <span class="text-accent text-sm font-body tracking-widest uppercase">04 — Projects</span>
      <span class="h-px flex-1 max-w-16 bg-accent/30" aria-hidden="true"></span>
    </div>

    <h2 class="font-heading font-bold leading-tight mb-4 proj-header-el" style="font-size: clamp(2rem, 5vw, 3.5rem);">
      Selected <span class="text-gradient">Work</span>
    </h2>
    <p class="text-secondary text-lg mb-24 max-w-xl proj-header-el">
      A curated collection of projects that demonstrate my craft.
    </p>

    <div class="projects-list space-y-8" role="list">
      {projects.map((project, i) => {
        const isEven  = i % 2 === 0;
        const rgb     = accentRgb[i % accentRgb.length];
        const hasLinks = project.links.android || project.links.ios || project.links.live || project.links.github;

        return (
          <article class="project-item group relative" role="listitem" data-index={i}>
            <div class={`project-card-inner grid md:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-border hover:border-accent/20 transition-colors duration-500 ${isEven ? '' : 'md:[direction:rtl]'}`}>

              <!-- ── Visual panel ── -->
              <div
                class="project-visual relative overflow-hidden min-h-[280px] md:min-h-[360px] md:[direction:ltr] flex items-center justify-center"
                style={`background: linear-gradient(135deg, #111111 0%, rgba(${rgb},0.07) 100%);`}
              >
                <!-- Top accent line -->
                <div
                  class="absolute top-0 left-0 right-0 h-px"
                  style={`background: linear-gradient(90deg, transparent, rgba(${rgb},0.5), transparent);`}
                  aria-hidden="true"
                ></div>

                <!-- Project logo centred -->
                {project.logo ? (
                  <div class="relative z-10 flex items-center justify-center p-10">
                    <img
                      src={project.logo}
                      alt={`${project.title} logo`}
                      class="project-logo max-w-[180px] max-h-[120px] w-auto h-auto object-contain drop-shadow-[0_0_24px_rgba(0,229,255,0.15)] transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ) : (
                  <!-- Fallback: big dim number -->
                  <div class="project-number absolute inset-0 flex items-center justify-center select-none pointer-events-none" aria-hidden="true">
                    <span class="font-heading font-bold opacity-[0.04] leading-none" style="font-size: clamp(8rem, 20vw, 16rem);">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                  </div>
                )}

                <!-- Store / link buttons inside visual panel (bottom) -->
                {hasLinks && (
                  <div class="absolute bottom-5 left-0 right-0 flex items-center justify-center gap-3 flex-wrap px-6 md:[direction:ltr]">
                    {project.links.android && (
                      <a
                        href={project.links.android}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="store-btn flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-white/10 bg-black/40 backdrop-blur-sm text-white/70 hover:text-white hover:border-white/30 transition-all duration-300 text-xs font-body"
                        aria-label={`${project.title} on Google Play`}
                        data-cursor="Google Play"
                      >
                        <!-- Play Store icon -->
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M3.18 23.76a2 2 0 0 1-1.04-.42L13 12 2.14.66a2 2 0 0 1 1.04-.42c.4 0 .8.14 1.12.42L17 10.56l-1.42 1.44L3.18 23.76z"/>
                          <path d="M20.82 14.1 17 12l1.1-1.1 3.72 2.06a1.5 1.5 0 0 1 0 2.68l-3.72 2.06L17 16.56l3.82-2.46z"/>
                          <path d="M2.14.66 14.58 13.1 3.3 24.34A2.02 2.02 0 0 1 3.18.24c.4 0 .8.14 1.12.42z" opacity=".3"/>
                        </svg>
                        Google Play
                      </a>
                    )}
                    {project.links.ios && (
                      <a
                        href={project.links.ios}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="store-btn flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-white/10 bg-black/40 backdrop-blur-sm text-white/70 hover:text-white hover:border-white/30 transition-all duration-300 text-xs font-body"
                        aria-label={`${project.title} on App Store`}
                        data-cursor="App Store"
                      >
                        <!-- Apple icon -->
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                        </svg>
                        App Store
                      </a>
                    )}
                    {project.links.live && (
                      <a
                        href={project.links.live}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="store-btn flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-white/10 bg-black/40 backdrop-blur-sm text-white/70 hover:text-white hover:border-white/30 transition-all duration-300 text-xs font-body"
                        aria-label={`${project.title} website`}
                        data-cursor="Visit Site"
                      >
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                          <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                        </svg>
                        Website
                      </a>
                    )}
                    {project.links.github && (
                      <a
                        href={project.links.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="store-btn flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-white/10 bg-black/40 backdrop-blur-sm text-white/70 hover:text-white hover:border-white/30 transition-all duration-300 text-xs font-body"
                        aria-label={`${project.title} on GitHub`}
                        data-cursor="GitHub"
                      >
                        <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/>
                        </svg>
                        GitHub
                      </a>
                    )}
                  </div>
                )}

                <!-- Hover glow -->
                <div
                  class="project-glow absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
                  style={`background: radial-gradient(ellipse 60% 60% at 50% 40%, rgba(${rgb},0.06) 0%, transparent 70%);`}
                  aria-hidden="true"
                ></div>
              </div>

              <!-- ── Content panel ── -->
              <div class="project-content bg-surface p-8 md:p-10 flex flex-col justify-between md:[direction:ltr]">
                <div>
                  <!-- Header: logo badge + featured -->
                  <div class="flex items-start justify-between mb-5">
                    <div class="flex items-center gap-3">
                      {project.logo && (
                        <div
                          class="w-9 h-9 rounded-xl overflow-hidden border border-border bg-bg flex items-center justify-center flex-shrink-0"
                          aria-hidden="true"
                        >
                          <img
                            src={project.logo}
                            alt=""
                            class="w-7 h-7 object-contain"
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                      )}
                      {project.featured && (
                        <span class="px-2 py-0.5 rounded text-accent border border-accent/30 text-xs font-body">
                          Featured
                        </span>
                      )}
                    </div>
                  </div>

                  <!-- Title -->
                  <h3 class="font-heading font-bold text-primary text-2xl md:text-3xl mb-4 group-hover:text-accent transition-colors duration-300 leading-tight">
                    {project.title}
                  </h3>

                  <!-- Description -->
                  <p class="text-secondary leading-relaxed mb-6 text-sm md:text-base">
                    {project.description}
                  </p>

                  <!-- Impact -->
                  <div class="flex items-start gap-3 p-4 rounded-xl border mb-6" style="background: rgba(0,229,255,0.03); border-color: rgba(0,229,255,0.1);">
                    <span class="text-accent text-base flex-shrink-0 mt-0.5" aria-hidden="true">↑</span>
                    <p class="text-primary text-sm leading-relaxed">{project.impact}</p>
                  </div>
                </div>

                <!-- Tech stack -->
                <div class="flex flex-wrap gap-2" aria-label="Technologies used">
                  {project.technologies.map((tech) => (
                    <span class="px-3 py-1.5 rounded-full bg-bg border border-border text-secondary text-xs font-body hover:text-accent hover:border-accent/30 transition-all duration-300">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<script>
  import { initProjectAnimations } from './ProjectAnimations';
  initProjectAnimations();
</script>
